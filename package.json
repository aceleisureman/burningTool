{
  "name": "stm32-flasher",
  "version": "1.0.0",
  "description": "STM32 可视化编译烧录工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "node scripts/dev.js",
    "start:prod": "vite build && electron .",
    "dev": "vite",
    "build:renderer": "vite build",
    "stop": "node scripts/stop-electron.js",
    "restart": "npm run stop && npm start",
    "test": "node --test",
    "lint": "eslint .",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --x64",
    "dist:mac": "vite build && electron-builder --mac --x64",
    "dist:mac-arm": "vite build && electron-builder --mac --arm64",
    "dist:mac-all": "vite build && electron-builder --mac --universal",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:all": "vite build && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.ruixin.mcutoolbox",
    "productName": "MCU工具箱",
    "copyright": "Copyright © 2026 锐新网络科技有限公司",
    "directories": {
      "output": "dist",
      "buildResources": "assets/icons"
    },
    "files": [
      "src/**/*",
      "renderer/dist/**/*",
      "assets/**/*",
      "!resources/**",
      "!dist",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": false,
    "win": {
      "icon": "assets/icons/256x256.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "STM32工具箱"
    },
    "portable": {
      "artifactName": "STM32工具箱-便携版-${version}.${ext}"
    },
    "mac": {
      "icon": "assets/icons/icon.icns"
    },
    "linux": {
      "icon": "assets/icons"
    }
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@eslint/js": "^9.14.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron-builder": "^25.1.8",
    "element-plus": "^2.9.1",
    "eslint": "^9.14.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "electron": "^35.7.5"
  },
  "allowScripts": {
    "electron@35.7.5": true
  },
  "dependencies": {
    "mqtt": "^5.15.1",
    "serialport": "^13.0.0"
  },
  "author": "STM32 Toolbox Team"
}
